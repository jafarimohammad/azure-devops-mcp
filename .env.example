# Base collection URL of your Azure DevOps Server 2022 (on-prem).
# Point this at the COLLECTION, not just the server.
AZDO_ORG_URL=https://devops.company.local/DefaultCollection

# Personal Access Token. Create one in Azure DevOps:
#   User settings (top-right) -> Personal access tokens -> New Token
# Scopes needed for the included tools:
#   Code (Read & Write)        -> repos, branches, files, pull requests
#   Build (Read & Execute)     -> list/get builds, run pipelines
AZDO_PAT=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: default project so you don't have to pass "project" on every call.
AZDO_PROJECT=MyProject

# Optional: REST API version. Azure DevOps Server 2022.0.x supports up to 7.0.
# (7.1 only exists on Azure DevOps Services and Server 2022.1+.)
AZDO_API_VERSION=7.0
